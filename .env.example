# Local port exposed on the NAS or development machine.
APP_PORT=3000

# Where holdings.json and future local app data should live.
DATA_PATH=./data

# Market/news cache duration in milliseconds. Default: 15 minutes.
CACHE_TTL_MS=900000

# Unraid commonly uses nobody:users as 99:100 for appdata writes.
PUID=99
PGID=100

# For docker-compose.yml local builds.
IMAGE_NAME=finance-dashboard:local

# For docker-compose.ghcr.yml, use this GitHub Container Registry image.
# IMAGE_NAME=ghcr.io/piskooooo/finance-dashboard:latest
